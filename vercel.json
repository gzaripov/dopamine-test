{
  "buildCommand": "bunx prisma generate && bun run build",
  "outputDirectory": "dist/client",
  "installCommand": "bun install",
  "framework": null,
  "regions": ["hnd1"],
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/ssr" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "CDN-Cache-Control", "value": "max-age=60, stale-while-revalidate=600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "max-age=60, stale-while-revalidate=600" }
      ]
    },
    {
      "source": "/test",
      "headers": [
        { "key": "CDN-Cache-Control", "value": "max-age=60, stale-while-revalidate=600" },
        { "key": "Vercel-CDN-Cache-Control", "value": "max-age=60, stale-while-revalidate=600" }
      ]
    }
  ],
  "functions": {
    "api/ssr.js": {
      "maxDuration": 30,
      "memory": 256,
      "includeFiles": "dist/server/**"
    }
  }
}
