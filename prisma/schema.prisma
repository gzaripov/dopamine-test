generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── App models ───────────────────────────────────────────────────────────────

model Assessment {
  id             String   @id @default(cuid())
  score          Int // 0–100
  tier           String // tier label
  categoryScores Json // { "screen-time": 45, "substances": 70, ... }
  completedAt    DateTime @default(now())
  shareToken     String   @unique @default(cuid()) // safe public URL ID

  answers Answer[]

  @@index([shareToken])
}

model Answer {
  id          String @id @default(cuid())
  questionId  String // e.g. "screen-time-1"
  categoryId  String // e.g. "screen-time"
  value       Int // raw 1–5
  scoredValue Int // pre-computed (inverted) value

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}
