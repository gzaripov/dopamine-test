generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── better-auth required models ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions    Session[]
  accounts    Account[]
  assessments Assessment[]
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@unique([identifier, value])
}

// ─── App models ───────────────────────────────────────────────────────────────

model Assessment {
  id             String   @id @default(cuid())
  score          Int // 0–100
  tier           String // tier label
  categoryScores Json // { "screen-time": 45, "substances": 70, ... }
  completedAt    DateTime @default(now())
  shareToken     String   @unique @default(cuid()) // safe public URL ID

  // Null for anonymous users
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  answers Answer[]

  @@index([userId])
  @@index([shareToken])
}

model Answer {
  id          String @id @default(cuid())
  questionId  String // e.g. "screen-time-1"
  categoryId  String // e.g. "screen-time"
  value       Int // raw 1–5
  scoredValue Int // pre-computed (inverted) value

  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
}
